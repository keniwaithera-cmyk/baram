<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Tenant Selection -->
        <androidx.cardview.widget.CardView
            style="@style/CardStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView android:text="Select Tenant"
                    android:textStyle="bold" android:textSize="16sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/primary_green"/>
                <Spinner android:id="@+id/spinnerTenant"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/tvHouseNo"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" android:textColor="@color/text_secondary"/>
                <TextView android:id="@+id/tvRentDue"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/primary_green" android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Payment Methods -->
        <androidx.cardview.widget.CardView
            style="@style/CardStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:text="Payment Method"
                    android:textStyle="bold" android:textSize="16sp"
                    android:textColor="@color/primary_green"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="12dp">

                    <!-- M-Pesa Manual -->
                    <androidx.cardview.widget.CardView android:id="@+id/cardMpesa"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_margin="4dp"
                        app:cardCornerRadius="8dp" app:cardElevation="2dp">
                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="8dp"
                            android:gravity="center">
                            <RadioButton android:id="@+id/rbMpesa"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:checked="true"/>
                            <TextView android:text="📱 M-Pesa" android:textSize="11sp"
                                android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Cash -->
                    <androidx.cardview.widget.CardView android:id="@+id/cardCash"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_margin="4dp"
                        app:cardCornerRadius="8dp" app:cardElevation="2dp">
                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="8dp"
                            android:gravity="center">
                            <RadioButton android:id="@+id/rbCash"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="💵 Cash" android:textSize="11sp"
                                android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Paybill -->
                    <androidx.cardview.widget.CardView android:id="@+id/cardPaybill"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_margin="4dp"
                        app:cardCornerRadius="8dp" app:cardElevation="2dp">
                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="8dp"
                            android:gravity="center">
                            <RadioButton android:id="@+id/rbPaybill"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="🏦 Paybill" android:textSize="11sp"
                                android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- STK Push -->
                    <androidx.cardview.widget.CardView android:id="@+id/cardStkPush"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_margin="4dp"
                        app:cardCornerRadius="8dp" app:cardElevation="2dp">
                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="8dp"
                            android:gravity="center">
                            <RadioButton android:id="@+id/rbStkPush"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="📲 STK Push" android:textSize="11sp"
                                android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Amount Field -->
        <androidx.cardview.widget.CardView
            style="@style/CardStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:text="Amount (KSh)"
                    android:textStyle="bold" android:textColor="@color/primary_green"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <EditText android:id="@+id/etAmount"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="numberDecimal" android:hint="Enter amount"
                    android:textSize="18sp" android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

                <!-- M-Pesa Code section -->
                <LinearLayout android:id="@+id/layoutMpesaDetails"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:layout_marginTop="8dp">
                    <TextView android:text="M-Pesa Transaction Code"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <EditText android:id="@+id/etMpesaCode"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="e.g. QGH2X3K9LM" android:inputType="textCapCharacters"/>
                </LinearLayout>

                <!-- Paybill instructions -->
                <LinearLayout android:id="@+id/layoutPaybillDetails"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:layout_marginTop="8dp"
                    android:visibility="gone">
                    <TextView android:text="📋 Paybill Instructions"
                        android:textStyle="bold" android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvPaybillNo"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvAccountNo"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- STK Push section -->
                <LinearLayout android:id="@+id/layoutStkPush"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:layout_marginTop="8dp"
                    android:visibility="gone">
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        app:cardCornerRadius="8dp" app:cardBackgroundColor="#E3F2FD">
                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="12dp">
                            <TextView android:text="📲 STK Push - Request Payment"
                                android:textStyle="bold" android:textColor="@color/stk_blue"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="• Tap 'Send STK Push' below\n• The tenant receives a payment prompt on their phone\n• Tenant enters their M-Pesa PIN to pay"
                                android:layout_marginTop="4dp" android:textColor="@color/text_secondary"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                    <Button android:id="@+id/btnStkPush"
                        style="@style/ButtonStkPush"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="📲 Send STK Push to Tenant"
                        android:layout_marginTop="12dp"/>
                </LinearLayout>

                <EditText android:id="@+id/etNotes"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Notes (optional)" android:layout_marginTop="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Landlord payment info -->
        <androidx.cardview.widget.CardView
            style="@style/CardStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:text="💳 Payment Details"
                    android:textStyle="bold" android:textColor="@color/primary_green"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvLandlordMpesa"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"/>
                <TextView android:id="@+id/tvPaybillNo"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvAccountNo"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Confirm Button -->
        <Button android:id="@+id/btnConfirmPayment"
            style="@style/ButtonPrimary"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="✅ Confirm Payment"
            android:layout_marginTop="8dp" android:layout_marginBottom="32dp"
            android:padding="16dp" android:textSize="16sp"/>

    </LinearLayout>
</ScrollView>
